{
	"traits_religion_lg": {
		"title": "Religion Traits: Lawful Good",
		"searchgroup": "trait",
		"compileFrom": {
			"source": "trait",
			"targets": [
				[
					"::main[Back to Religion Traits]{to=main/traits_religion rev}",
					""
				],
				{
					"limit": { "regex": "\\bLG-[^,]+" },
					"sort": [ "match", "name" ],
					"join": [ "", "", "" ],
					"modifyDescription": {
						"regex": "((?:\\*\\*.+?!-N-!)+!-N-!)(.+)",
						"replacement": "$1!-SOURCE-!  !-N-!$2"
					},
					"template": ":::item!-N-!!-N-!## ‹trait/!-TITLE-!›!-N-!!-N-!!-DESC-!!-N-!!-N-!:::"
				}
			]
		}
	},
