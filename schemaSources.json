{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://jasontank.net/sources.pfdata.schema.json",
	"title": "Pf Data 1e : Sources",
	"description": "A collection of information about source documents.",
	"$comment": "This schema is specifically for ./src/json/sources.json",
	"type": "object",
	"patternProperties": {
		"^[a-z_][a-z0-9_]*$": {
			"anyOf": [
				{
					"$comment": "Source entries",
					"type": "object",
					"properties": {
						"title": "string",
						"url": {
							"type": "string",
							"pattern": "^https?://[a-z.]+/[^\" ]*$",
							"$comment": "THIS IS NOT A GOOD URL VALIDATION REGEXP, it's just good enough for this project."
						},
						"required": [ "title", "url" ]
					},
					"unevaluatedProperties": false
				},
				{
					"$comment": "Not Found entry",
					"type": "object",
					"properties": {
						"title": "string",
						"url": {
							"type": "string",
							"pattern": "^$"
						},
						"unknown": "boolean"
					},
					"required": [ "title", "url", "unknown" ],
					"unevaluatedProperties": false
				}
			]
		},
		"unevaluatedProperties": false
	},
	"unevaluatedProperties": false
}
