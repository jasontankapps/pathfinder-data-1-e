{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://jasontank.net/featTree.pfdata.schema.json",
	"title": "Pf Data 1e - Feats",
	"description": "A collection of information about a specific part of the Pathfinder system.",
	"$comment": "This is exclusively for feat_tree_data.json",
	"type": "array",
	"items": {
		"type": "object",
		"properties": {
			"prop": { "type": "string" },
			"primary": { "type": "boolean" },
			"leaves": {
				"type": "array",
				"items": {
					"type": "object",
					"properties": {
						"prop": { "type": "string" },
						"primary": { "type": "boolean" },
						"coparents": { "$ref": "#uniqueArray" },
						"coparentsNoLink": { "type": "boolean" },
						"leaves": {
							"type": "array",
							"items": { "$ref": "#subfeat" },
							"unevaluatedItems": false
						}
					},
					"dependentRequired": {
						"coparentsNoLink": [ "coparents" ]
					},
					"required": [ "prop" ],
					"unevaluatedProperties": false
				},
				"unevaluatedItems": false
			}
		},
		"required": [ "prop" ],
		"unevaluatedProperties": false
	},
	"unevaluatedItems": false
}
